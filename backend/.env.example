# ==========================================
# Variables de entorno - Health Flow API
# ==========================================

# URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_base_de_datos
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/healthflow_db

# Clave secreta para firmar los tokens JWT
# Puedes generar una usando: openssl rand -hex 32
SECRET_KEY=cambia_esta_clave_por_una_muy_segura_y_larga

# Algoritmo de encriptación para los tokens
ALGORITHM=HS256

# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Variables opcionales para desarrollo
DEBUG=True
ENVIRONMENT=development